---
const navLinks = [
  { href: '/vergleich', label: 'Kurse vergleichen' },
  { href: '/ratgeber', label: 'Ratgeber' },
  { href: '/foerderrechner', label: 'Förderrechner' },
  { href: '/quiz', label: 'Quiz' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="text-[#2563EB] font-bold text-lg tracking-tight hover:opacity-80 transition">
      KI-Kurs-Vergleich.de
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`hover:text-[#2563EB] transition pb-0.5 ${currentPath.startsWith(link.href) ? 'text-[#2563EB] border-b-2 border-[#2563EB]' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile Hamburger (CSS-only) -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-gray-600 hover:text-[#2563EB]" aria-label="Menü öffnen">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <!-- Mobile Menu (CSS-only via hidden checkbox) -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <nav class="hidden peer-checked:block md:hidden bg-white border-t border-gray-100 px-4 py-3">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`block py-2 text-sm font-medium hover:text-[#2563EB] transition ${currentPath.startsWith(link.href) ? 'text-[#2563EB]' : 'text-gray-600'}`}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>
