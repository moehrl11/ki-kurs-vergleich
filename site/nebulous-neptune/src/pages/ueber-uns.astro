---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Über uns" description="Wer hinter KI-Kurs-Vergleich.de steckt und wie wir arbeiten.">

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <div class="mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Über KI-Kurs-Vergleich.de</h1>
      <p class="text-lg text-gray-500 max-w-2xl">
        Wir sind ein unabhängiges Portal — kein Kursanbieter, kein Institut. Unser einziges Ziel: dir helfen, den richtigen KI-Kurs zu finden.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-16">

      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="w-10 h-10 bg-[#2563EB]/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 mb-2">Unabhängig</h2>
        <p class="text-sm text-gray-500">Kein Kursanbieter bezahlt uns für bessere Platzierungen. Unsere Bewertungen basieren auf öffentlich verfügbaren Informationen.</p>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="w-10 h-10 bg-[#10B981]/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#10B981]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 mb-2">Transparent</h2>
        <p class="text-sm text-gray-500">Wir verdienen über Affiliate-Provisionen, wenn du über unsere Links buchst. Das steht auf jeder Seite offen dabei.</p>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="w-10 h-10 bg-[#2563EB]/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 mb-2">Kostenlos</h2>
        <p class="text-sm text-gray-500">Der Vergleich, der Förderrechner und der Kurs-Finder sind für dich kostenlos — ohne Registrierung, ohne Paywall.</p>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="w-10 h-10 bg-[#10B981]/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#10B981]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 mb-2">Deutschland-Fokus</h2>
        <p class="text-sm text-gray-500">Wir berücksichtigen deutsche Förderungen, AZAV-Zertifizierungen und den deutschen Arbeitsmarkt — kein generischer internationaler Kursvergleich.</p>
      </div>

    </div>

    <!-- B2B Formular -->
    <div class="bg-white rounded-xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">KI-Schulung für Ihr Unternehmen?</h2>
      <p class="text-gray-500 mb-8">Wir helfen Ihnen das passende Angebot für Ihr Team zu finden — kostenlos und unverbindlich.</p>

      <form action="https://formspree.io/f/PLACEHOLDER" method="POST" class="space-y-5">

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
            <input type="text" id="name" name="name" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-Mail geschäftlich <span class="text-red-500">*</span></label>
            <input type="email" id="email" name="email" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="unternehmen" class="block text-sm font-medium text-gray-700 mb-1">Unternehmen <span class="text-red-500">*</span></label>
            <input type="text" id="unternehmen" name="unternehmen" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent" />
          </div>
          <div>
            <label for="mitarbeiter" class="block text-sm font-medium text-gray-700 mb-1">Anzahl Mitarbeiter</label>
            <select id="mitarbeiter" name="mitarbeiter"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent bg-white">
              <option value="">Bitte wählen</option>
              <option value="1-5">1–5</option>
              <option value="6-20">6–20</option>
              <option value="21-50">21–50</option>
              <option value="50+">50+</option>
            </select>
          </div>
        </div>

        <div>
          <label for="nachricht" class="block text-sm font-medium text-gray-700 mb-1">Nachricht (optional)</label>
          <textarea id="nachricht" name="nachricht" rows="4"
            placeholder="Was möchten Sie schulen? Wie viele Personen? Welcher Zeitraum?"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent resize-none"></textarea>
        </div>

        <button type="submit"
          class="bg-[#2563EB] text-white font-semibold px-6 py-3 rounded-lg hover:bg-blue-700 transition shadow-sm">
          Anfrage senden
        </button>

      </form>
    </div>

  </div>

</BaseLayout>
