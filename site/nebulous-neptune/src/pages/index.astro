---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const artikel = (await getCollection('ratgeber'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="KI-Kurse vergleichen" description="10 KI-Weiterbildungen im Vergleich — von kostenlos bis intensiv. Mit Förderbarkeit, Zertifikat und Zielgruppe auf einen Blick.">

  <!-- Hero -->
  <section class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-6">
        Dein Vergleich<br class="hidden sm:block" /> für KI-Weiterbildungen
      </h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10">
        Wir vergleichen KI-Kurse transparent nach Inhalt, Preis und Förderbarkeit —
        damit du die richtige Entscheidung für deine Karriere triffst.
      </p>
      <a href="/vergleich" class="inline-block bg-[#2563EB] text-white font-semibold px-8 py-3 rounded-lg hover:bg-blue-700 transition shadow-sm">
        Jetzt Kurse vergleichen
      </a>
    </div>
  </section>

  <!-- Einstiegskarten -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid sm:grid-cols-3 gap-6">

      <!-- Karte 1: Kurse vergleichen -->
      <a href="/vergleich" class="group bg-white rounded-xl border border-gray-200 p-8 hover:border-[#2563EB] hover:shadow-md transition">
        <div class="w-12 h-12 bg-[#2563EB]/10 rounded-lg flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-[#2563EB] transition">Kurse vergleichen</h2>
        <p class="text-sm text-gray-500">Alle relevanten KI-Weiterbildungen auf einen Blick — nach Preis, Dauer und Zertifikat gefiltert.</p>
      </a>

      <!-- Karte 2: Kurs-Quiz -->
      <a href="/quiz" class="group bg-white rounded-xl border border-gray-200 p-8 hover:border-[#10B981] hover:shadow-md transition">
        <div class="w-12 h-12 bg-[#10B981]/10 rounded-lg flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#10B981]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-[#10B981] transition">Quiz: Welcher Kurs passt?</h2>
        <p class="text-sm text-gray-500">In 3 Minuten zur persönlichen Kursempfehlung — basierend auf deinem Vorwissen und Lernziel.</p>
      </a>

      <!-- Karte 3: Für Unternehmen -->
      <a href="/unternehmen" class="group bg-white rounded-xl border border-gray-200 p-8 hover:border-[#2563EB] hover:shadow-md transition">
        <div class="w-12 h-12 bg-[#2563EB]/10 rounded-lg flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#2563EB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-[#2563EB] transition">Für Unternehmen</h2>
        <p class="text-sm text-gray-500">Gruppentrainings, Fördermöglichkeiten und maßgeschneiderte KI-Schulungen für dein Team.</p>
      </a>

    </div>
  </section>

  <!-- Trust-Leiste -->
  <section class="bg-white border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-10 flex flex-col sm:flex-row items-center justify-center gap-10 text-sm text-gray-400 text-center">
      <div><span class="block text-2xl font-bold text-gray-800 mb-1">15</span>Kurse verglichen</div>
      <div class="hidden sm:block w-px h-10 bg-gray-200"></div>
      <div><span class="block text-2xl font-bold text-gray-800 mb-1">AZAV</span>Förderbarkeit geprüft</div>
      <div class="hidden sm:block w-px h-10 bg-gray-200"></div>
      <div><span class="block text-2xl font-bold text-gray-800 mb-1">EU AI Act</span>Compliance-Kurse dabei</div>
    </div>
  </section>

  <!-- Ratgeber-Vorschau -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-gray-900">Ratgeber & Tipps</h2>
      <a href="/ratgeber" class="text-sm font-semibold text-[#2563EB] hover:underline">Alle Artikel →</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-6">
      {artikel.map(a => (
        <a href={`/ratgeber/${a.data.slug}`} class="group bg-white rounded-xl border border-gray-200 p-6 hover:border-[#2563EB] hover:shadow-md transition">
          <div class="flex items-center gap-2 text-xs text-gray-400 mb-3">
            <span>{a.data.date}</span>
            {a.data.lesezeit && <span>· {a.data.lesezeit}</span>}
          </div>
          <h3 class="font-semibold text-gray-900 leading-snug mb-2 group-hover:text-[#2563EB] transition">{a.data.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{a.data.description}</p>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
