---

<BaseLayout title="KI-Kurse vergleichen" description="15 KI-Weiterbildungen im Vergleich — von kostenlos bis intensiv. Mit Förderbarkeit, Zertifikat und Zielgruppe.">

  <div class="max-w-6xl mx-auto px-4 py-12">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">KI-Kurse im Vergleich</h1>
      <p class="text-gray-500 max-w-2xl">15 geprüfte Weiterbildungen — von kostenlos bis intensiv.</p>
      <p class="text-xs text-gray-400 max-w-2xl mt-2">Wie wir vergleichen: Alle aufgeführten Kurse wurden selbst recherchiert und auf Basis öffentlich verfügbarer Anbieterinformationen bewertet. Geprüft wurden Preis, Dauer, Format, Zertifikat, Zielgruppe und Förderbarkeit über Bildungsgutschein oder QCG. Die AZAV-Zertifizierung wurde direkt auf den Anbieter-Websites verifiziert. Daten werden regelmäßig aktualisiert. <a href="/so-vergleichen-wir" class="text-[#2563EB] hover:underline">→ Mehr zur Methodik</a></p>
    </div>

    <!-- Empfehlungsbox -->
    <div class="bg-[#2563EB]/5 border border-[#2563EB]/20 rounded-xl p-6 mb-8">
      <p class="text-xs font-semibold text-[#2563EB] uppercase tracking-wider mb-3">Schnellübersicht: Was passt zu mir?</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 text-sm">
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Arbeitssuchende:</strong> SkillSprinters oder Hilker Consulting (100% kostenlos)</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Wenig Zeit:</strong> XDi Certified AI Professional (2 Tage)</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Führungskräfte:</strong> Haufe Akademie KI-Manager</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Karrierewechsel:</strong> neue fische AI Bootcamp</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Kostenloser Einstieg:</strong> Elements of AI (IHK)</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Günstig & schnell:</strong> Udemy ChatGPT Kurs</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Renommiertes Zertifikat:</strong> Fraunhofer KI-Manager</span>
        </div>
        <div class="flex gap-2 items-start">
          <span class="text-[#10B981] font-bold shrink-0">→</span>
          <span><strong>Schnellster Einstieg:</strong> Google AI Essentials (10h, kostenlos)</span>
        </div>
      </div>
    </div>

    <!-- Filter -->
    <div class="flex flex-wrap gap-2 mb-6" id="filter-bar">
      <button onclick="filterKurse('alle')" data-filter="alle" class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold border border-[#2563EB] bg-[#2563EB] text-white transition">
        Alle (15)
      </button>
      <button onclick="filterKurse('gefoerdert')" data-filter="gefoerdert" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-[#2563EB] hover:text-[#2563EB] transition">
        ✅ Förderbar (7)
      </button>
      <button onclick="filterKurse('kostenlos')" data-filter="kostenlos" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-[#2563EB] hover:text-[#2563EB] transition">
        🎓 Kostenlos (3)
      </button>
      <button onclick="filterKurse('premium')" data-filter="premium" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-[#2563EB] hover:text-[#2563EB] transition">
        ⭐ Premium (3)
      </button>
      <button onclick="filterKurse('guenstig')" data-filter="guenstig" class="filter-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-200 text-gray-600 hover:border-[#2563EB] hover:text-[#2563EB] transition">
        💸 Günstig (3)
      </button>
    </div>

    <!-- Interaktive Tabelle -->
    <div class="overflow-x-auto rounded-xl border border-gray-200 mb-6">
      <table class="w-full text-sm" id="kurs-tabelle">
        <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wider">
          <tr>
            <th class="px-4 py-3 text-left">Kurs</th>
            <th class="px-4 py-3 text-left hidden sm:table-cell">Für wen</th>
            <th class="px-4 py-3 text-left">Preis</th>
            <th class="px-4 py-3 text-left hidden sm:table-cell">Dauer</th>
            <th class="px-4 py-3 text-left hidden md:table-cell">Zertifikat</th>
            <th class="px-4 py-3 text-left hidden sm:table-cell">Förderung</th>
            <th class="px-4 py-3 text-left">Details</th>
          </tr>
        </thead>
        <tbody>
          {kurse.map((kurs) => (
            <Fragment>
              <tr
                class="kurs-zeile border-t border-gray-100 hover:bg-gray-50 transition cursor-pointer"
                data-kategorie={kurs.kategorie}
                data-foerderbar={kurs.foerderbar}
                onclick={`toggleDetail(${kurs.id})`}
              >
                <td class="px-4 py-3">
                  <p class="font-medium text-gray-900">{kurs.name}</p>
                  <p class="text-xs text-gray-400 mb-1">{kurs.anbieter}</p>
                  {kurs.kategorie === 'kostenlos' && <span class="inline-block bg-[#10B981]/10 text-[#10B981] text-xs font-semibold px-2 py-0.5 rounded-full">Kostenlos</span>}
                  {kurs.foerderbar === 'ja' && kurs.kategorie !== 'kostenlos' && <span class="inline-block bg-blue-50 text-[#2563EB] text-xs font-semibold px-2 py-0.5 rounded-full">Förderbar</span>}
                  {kurs.kategorie === 'premium' && kurs.foerderbar !== 'ja' && <span class="inline-block bg-amber-50 text-amber-600 text-xs font-semibold px-2 py-0.5 rounded-full">Premium</span>}
                  {kurs.kategorie === 'guenstig' && <span class="inline-block bg-gray-100 text-gray-500 text-xs font-semibold px-2 py-0.5 rounded-full">Günstig</span>}
                </td>
                <td class="px-4 py-3 text-gray-600 text-xs hidden sm:table-cell">{kurs.zielgruppe}</td>
                <td class="px-4 py-3 font-medium text-gray-900 text-xs whitespace-nowrap">{kurs.preis}</td>
                <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap hidden sm:table-cell">{kurs.dauer}</td>
                <td class="px-4 py-3 text-gray-600 text-xs hidden md:table-cell">{kurs.abschluss}</td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  {kurs.foerderbar === 'ja' && <span class="inline-block bg-[#10B981]/10 text-[#10B981] text-xs font-semibold px-2 py-0.5 rounded-full">Ja</span>}
                  {kurs.foerderbar === 'teilweise' && <span class="inline-block bg-amber-50 text-amber-600 text-xs font-semibold px-2 py-0.5 rounded-full">Teilw.</span>}
                  {kurs.foerderbar === 'nein' && <span class="inline-block bg-gray-100 text-gray-400 text-xs px-2 py-0.5 rounded-full">Nein</span>}
                </td>
                <td class="px-4 py-3">
                  <button id={`btn-${kurs.id}`} class="text-[#2563EB] text-xs font-medium whitespace-nowrap select-none">
                    Details ▼
                  </button>
                </td>
              </tr>
              <tr
                class="detail-zeile hidden border-t border-gray-100 bg-gray-50/50"
                id={`detail-${kurs.id}`}
                data-kategorie={kurs.kategorie}
                data-foerderbar={kurs.foerderbar}
              >
                <td colspan="7" class="px-6 py-5">
                  <p class="text-[#2563EB] font-semibold mb-3">{kurs.highlight}</p>
                  <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-gray-500 mb-3">
                    <span>💻 Format: {kurs.format}</span>
                    <span>🎯 Zielgruppe: {kurs.zielgruppe}</span>
                    <span>📜 Zertifikat: {kurs.abschluss}</span>
                  </div>
                  <p class="text-xs text-gray-400 mb-4">
                    <span class="text-red-400 font-medium">✗ Weniger passend wenn</span> {kurs.nichtGeeignet}
                  </p>
                  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
                    <p class="text-xs text-gray-400 italic max-w-lg">{kurs.einschaetzung}</p>
                    <div class="flex flex-col items-start sm:items-end gap-1 shrink-0">
                      <a
                        href={kurs.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-block bg-[#2563EB] text-white text-sm font-semibold px-5 py-2 rounded-lg hover:bg-blue-700 transition whitespace-nowrap"
                      >
                        {kurs.foerderbar === 'ja' ? 'Förderoptionen prüfen →' : kurs.preisNum === 0 ? 'Kostenlos starten →' : kurs.preisNum > 1000 ? 'Kursdetails ansehen →' : 'Zum Anbieter →'}
                      </a>
                      <span class="text-xs text-gray-300">* Affiliate-Link</span>
                    </div>
                  </div>
                  <p class="text-xs text-gray-300 mt-4 pt-3 border-t border-gray-100">Zuletzt geprüft: März 2026</p>
                </td>
              </tr>
            </Fragment>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Keine Ergebnisse -->
    <div id="keine-ergebnisse" class="hidden text-center py-12 text-gray-400">
      Keine Kurse in dieser Kategorie gefunden.
    </div>

    <!-- Förderhinweis -->
    <div class="mt-10 bg-[#10B981]/10 border border-[#10B981]/30 rounded-xl p-6 flex gap-4 items-start">
      <svg class="w-6 h-6 text-[#10B981] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
      </svg>
      <div>
        <p class="font-semibold text-gray-800 mb-1">Bis zu 100% Förderung möglich</p>
        <p class="text-sm text-gray-600">
          Viele KI-Kurse sind über den Bildungsgutschein (AZAV) oder das Qualifizierungschancengesetz förderbar.
          Nutze unseren <a href="/foerderrechner" class="text-[#2563EB] underline hover:no-underline">Förderrechner</a>, um deinen Anspruch zu prüfen.
          Mehr dazu im <a href="/ratgeber/ki-kurs-bildungsgutschein" class="text-[#2563EB] underline hover:no-underline">Ratgeber: KI-Kurs mit Bildungsgutschein</a>.
        </p>
      </div>
    </div>

  </div>

</BaseLayout>

<script is:inline>
  function toggleDetail(id) {
    var detail = document.getElementById('detail-' + id);
    var btn = document.getElementById('btn-' + id);
    var isOpen = !detail.classList.contains('hidden');
    detail.classList.toggle('hidden', isOpen);
    btn.textContent = isOpen ? 'Details ▼' : 'Details ▲';
  }

  function filterKurse(kategorie) {
    var zeilen = document.querySelectorAll('.kurs-zeile');
    var sichtbar = 0;

    zeilen.forEach(function(zeile) {
      var kat = zeile.getAttribute('data-kategorie');
      var foerderbar = zeile.getAttribute('data-foerderbar');
      var zeigen = false;

      if (kategorie === 'alle') {
        zeigen = true;
      } else if (kategorie === 'gefoerdert') {
        zeigen = foerderbar === 'ja';
      } else {
        zeigen = kat === kategorie;
      }

      var id = zeile.getAttribute('onclick').replace('toggleDetail(', '').replace(')', '');
      var detailZeile = document.getElementById('detail-' + id);

      if (zeigen) {
        zeile.classList.remove('hidden');
        sichtbar++;
      } else {
        zeile.classList.add('hidden');
        // Detail zuklappen wenn gefiltert
        if (detailZeile) {
          detailZeile.classList.add('hidden');
          var btn = document.getElementById('btn-' + id);
          if (btn) btn.textContent = 'Details ▼';
        }
      }

      if (detailZeile) {
        detailZeile.classList.toggle('hidden', !zeigen || detailZeile.classList.contains('hidden'));
        // Nur verstecken wenn Zeile versteckt — nicht aufklappen
        if (!zeigen) detailZeile.classList.add('hidden');
      }
    });

    document.getElementById('keine-ergebnisse').classList.toggle('hidden', sichtbar > 0);

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      var isActive = btn.getAttribute('data-filter') === kategorie;
      btn.classList.toggle('bg-[#2563EB]', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-[#2563EB]', isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('border-gray-200', !isActive);
    });
  }
</script>
