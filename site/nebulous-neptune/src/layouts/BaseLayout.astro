---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Der unabhängige Vergleich für KI-Weiterbildungen in Deutschland.' } = Astro.props;
const ogTitle = `${title} | KI-Kurs-Vergleich.de`;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KI-Kurs-Vergleich.de" />
    <meta property="og:image" content="https://www.ki-kurs-vergleich.de/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.ki-kurs-vergleich.de/og-image.svg" />
    <title>{ogTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="97z7Y-AJ2slKUQ6vVEmT1rBw-MwIo4fpAldLjNhAV1U" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VY6H5CCPK7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VY6H5CCPK7');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-blue: #2563EB;
        --color-green: #10B981;
        --color-bg: #F9FAFB;
        --color-text: #111827;
      }
      body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
  </head>
  <body class="bg-[#F9FAFB] text-[#111827] min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
