---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Der unabhängige Vergleich für KI-Weiterbildungen in Deutschland.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | KI-Kurs-Vergleich.de</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#F9FAFB] text-gray-800 min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-[#2563EB] font-bold text-xl tracking-tight hover:opacity-80 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .3 2.7-1.1 2.7H3.9c-1.4 0-2.1-1.7-1.1-2.7L4.2 15.3" />
          </svg>
          KI-Kurs-Vergleich.de
        </a>
        <nav class="flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/vergleich" class="hover:text-[#2563EB] transition">Vergleich</a>
          <a href="/ratgeber" class="hover:text-[#2563EB] transition">Ratgeber</a>
          <a href="/foerderrechner" class="hover:text-[#2563EB] transition">Förderrechner</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} KI-Kurs-Vergleich.de — Unabhängige Kursvergleiche</p>
        <nav class="flex gap-6">
          <a href="/impressum" class="hover:text-gray-800 transition">Impressum</a>
          <a href="/datenschutz" class="hover:text-gray-800 transition">Datenschutz</a>
        </nav>
      </div>
    </footer>

  </body>
</html>
